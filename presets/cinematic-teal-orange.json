{
  "schema_version": 1,
  "id": "cinematic-teal-orange",
  "display_name": "Cinematic Teal/Orange",
  "description": "DaVinci-classic cinematography look: teal shadows, orange highlights, and a mild S-curve.",
  "compose_ops": [
    {
      "op": "lab_color_shift",
      "primitive": "N-08",
      "params": {
        "shadow_shift": {"L_threshold": 0.42, "a_shift": -5.0, "b_shift": -10.0},
        "highlight_shift": {"L_threshold": 0.58, "a_shift": 5.0, "b_shift": 12.0}
      }
    },
    {
      "op": "tone_curve_s",
      "primitive": "N-09",
      "params": {
        "curve_points": [[0.0, 0.0], [0.15, 0.1], [0.3, 0.25], [0.45, 0.43], [0.55, 0.57], [0.7, 0.75], [0.85, 0.9], [1.0, 1.0]]
      }
    }
  ],
  "default_intensity": 1.0,
  "protect_skin_default": false
}
